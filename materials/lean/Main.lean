/-
M-types as a quotient: the type of *all* pointed coalgebras ("unfoldings"),
quotiented by bisimilarity.

I (@kory33) think this construction follows the idea described in
the paper by Gylterud et al. (https://arxiv.org/abs/2001.06696), which in turn
refers to the work of Aczel and Mendler (https://doi.org/10.1007/BFb0018361),
but I have not verified the correspondence in detail. The Agda formalization of
Gylterud et al. is at https://github.com/niccoloveltri/aczel-mendler, and it seems to define
the weakly terminal coalgebra as a union of all (unpointed) coalgebras, so
there's already a difference in the definition of the carrier (I am not certain how essential this is).

Contrast with Mathlib's `PFunctor.M` (ŌČ-limit of approximations) and
`QPF.Cofix` (quotient of `PFunctor.M` by `Mcongr`): here the carrier is the
generation state itself, so `dest` costs one application of the step map,
definitionally, independent of access path.

Implemented primarily by Claude Fable 5, refactored and commented by @kory33, 2026-07-09.
-/
import Mathlib.Data.PFunctor.Univariate.M

namespace PFunctor

/-- A pointed coalgebra: a carrier, a step map, and a current state.
    This is morally "the tree generated by unfolding `step` from `pt`",
    represented by its generation state rather than by the tree.

    Quantifying over carriers in `Type w` puts this one universe up. -/
structure UnfoldingMachine (P : PFunctor.{u, v}) : Type (max (max u v) (w + 1)) where
  S : Type w
  step : S ‚Üí P.Obj S
  state : S

namespace UnfoldingMachine

variable {P : PFunctor}

/-- Root label. -/
def head (x : P.UnfoldingMachine) : P.A := (x.step x.state).1

/-- Subtree at branch `i`: same machine, advanced state. -/
def child (x : P.UnfoldingMachine) (i : P.B x.head) : P.UnfoldingMachine :=
  { x with state := (x.step x.state).2 i }

/-- One observation step, packaged as a `P.Obj` of unfoldings. -/
def destructure (x : P.UnfoldingMachine) : P.Obj P.UnfoldingMachine :=
  ‚ü®x.head, x.child‚ü©

/-- Unfolding machine's state type is hidden inside ő£, and the only data one could observe is
    the tree of labels produced by the unfolding.

    A natural thing to do is to *identify* two machines if one can never distinguish them by
    observing labels produced by them. This coinductive predicate captures this idea, and asserts that
    the root label of two unfolding machines are equal, and (coinductively) their evolutions
    also behave identically.

    In computer science, this relation is known as *bisimilarity*.
-/
coinductive EqBehavior : P.UnfoldingMachine ‚Üí P.UnfoldingMachine ‚Üí Prop
  | intro (x y : P.UnfoldingMachine)
      (a f g) (hx : x.destructure = ‚ü®a, f‚ü©) (hy : y.destructure = ‚ü®a, g‚ü©)
      (children_bisim : ‚ąÄ i, EqBehavior (f i) (g i)) :
      EqBehavior x y

theorem EqBehavior.refl (x : P.UnfoldingMachine) : EqBehavior x x :=
  EqBehavior.coinduct Eq
    (fun a _ h => h ‚Ėł ‚ü®a.head, a.child, a.child, rfl, rfl, fun _ => rfl‚ü©) x x rfl

theorem EqBehavior.symm {x y : P.UnfoldingMachine} (h : EqBehavior x y) : EqBehavior y x :=
  EqBehavior.coinduct (fun a b => EqBehavior b a) (fun _ _ hba => by
    cases hba with | intro b a c f g hbf hag k => exact ‚ü®c, g, f, hag, hbf, k‚ü©) y x h

theorem EqBehavior.trans {x y z : P.UnfoldingMachine} (hxy : EqBehavior x y) (hyz : EqBehavior y z) :
    EqBehavior x z := by
  refine EqBehavior.coinduct (fun a c => ‚ąÉ b, EqBehavior a b ‚ąß EqBehavior b c) ?_ x z ‚ü®y, hxy, hyz‚ü©
  rintro a c ‚ü®b, h‚āĀ, h‚āā‚ü©
  cases h‚āĀ with | intro a b a‚āĀ f‚āĀ g‚āĀ ha‚āĀ hb‚āĀ k‚āĀ =>
  cases h‚āā with | intro b c a‚āā f‚āā g‚āā hb‚āā hc‚āā k‚āā =>
  cases hb‚āĀ.symm.trans hb‚āā
  exact ‚ü®a‚āĀ, f‚āĀ, g‚āā, ha‚āĀ, hc‚āā, fun i => ‚ü®g‚āĀ i, k‚āĀ i, k‚āā i‚ü©‚ü©

instance setoid (P : PFunctor) : Setoid P.UnfoldingMachine :=
  ‚ü®EqBehavior, ‚ü®EqBehavior.refl, EqBehavior.symm, EqBehavior.trans‚ü©‚ü©

end UnfoldingMachine

/-- The M-type as a quotient: all unfoldings modulo bisimilarity.
Lives in `Type (max _ (w+1))`, at least one level above the coalgebra carriers. -/
def MQ (P : PFunctor) : Type _ := Quotient (UnfoldingMachine.setoid P)

namespace MQ

variable {P : PFunctor}

/-- Corecursion -/
def corec {S : Type v} (g : S ‚Üí P.Obj S) (x : S) : P.MQ := ‚ü¶‚ü®S, g, x‚ü©‚üß

/-- Destructor: run the machine one step, re-package the successor states.
We lift the function which operates on particular state type. -/
def destructure : P.MQ ‚Üí P.Obj P.MQ :=
  Quotient.lift (fun x => ‚ü®x.head, fun i => ‚ü¶x.child i‚üß‚ü©) <| fun x y hxy => by
    have hxy : UnfoldingMachine.EqBehavior x y := hxy
    cases hxy with | intro x y a f g hx hy k =>
    show P.map (‚ü¶¬∑‚üß) x.destructure = P.map (‚ü¶¬∑‚üß) y.destructure
    rw [hx, hy, PFunctor.map_eq, PFunctor.map_eq]
    exact congrArg _ (funext fun i => Quotient.sound (k i))

/-- `corec` is a coalgebra morphism. -/
@[simp] theorem dest_corec {X : Type v} (g : X ‚Üí P.Obj X) (x : X) :
    (corec g x : P.MQ).destructure = P.map (corec g) (g x) := rfl

/-- `destructure` computes on `‚ü¶¬∑‚üß`. -/
@[simp] theorem destructure_mk (x : P.UnfoldingMachine) :
    destructure ‚ü¶x‚üß = P.map (‚ü¶¬∑‚üß) x.destructure := rfl

/-- Coinduction: every dest-compatible relation is contained in equality.
This is where the quotient earns its keep over the bare (weakly terminal)
`UnfoldingMachine` type. -/
theorem bisim (R : P.MQ ‚Üí P.MQ ‚Üí Prop)
    (h : ‚ąÄ a b, R a b ‚Üí ‚ąÉ a' f g,
      a.destructure = ‚ü®a', f‚ü© ‚ąß b.destructure = ‚ü®a', g‚ü© ‚ąß ‚ąÄ i, R (f i) (g i)) :
    ‚ąÄ a b, R a b ‚Üí a = b := fun a b =>
  Quotient.inductionOn‚āā a b fun p q hpq =>
    -- `destructure ‚ü¶u‚üß ‚Č° P.map ‚ü¶¬∑‚üß u.destructure`, so `h` pulls back to a
    -- bisimulation on unfoldings; coinduction then gives `EqBehavior`.
    Quotient.sound <| UnfoldingMachine.EqBehavior.coinduct (fun u v => R ‚ü¶u‚üß ‚ü¶v‚üß) (by
      intro u v huv
      obtain ‚ü®c, fq, gq, hu, hv, hfg‚ü© := h _ _ huv
      rcases eu : u.destructure with ‚ü®ua, uf‚ü©
      rcases ev : v.destructure with ‚ü®va, vf‚ü©
      simp only [destructure_mk, eu, ev, PFunctor.map_eq] at hu hv
      cases hu; cases hv
      exact ‚ü®_, uf, vf, rfl, rfl, hfg‚ü©) p q hpq

/-- Uniqueness half of finality, against coalgebras with `Type v` carriers.
Together with `dest_corec`: `MQ` is "V-terminal" (Gylterud‚ÄďStenholm‚ÄďVeltri);
no terminality in its own universe is claimed. -/
theorem corec_unique {X : Type v} (g : X ‚Üí P.Obj X)
    (f : X ‚Üí P.MQ) (f_homomorphic : ‚ąÄ x, (f x).destructure = P.map f (g x)) :
    f = corec g := by
  funext x‚āÄ
  refine bisim (fun a b => ‚ąÉ x, a = f x ‚ąß b = corec g x) ?_ _ _ ‚ü®x‚āÄ, rfl, rfl‚ü©
  rintro a b ‚ü®x, rfl, rfl‚ü©
  exact ‚ü®(g x).1, fun i => f ((g x).2 i), fun i => corec g ((g x).2 i),
    f_homomorphic x, rfl, fun i => ‚ü®(g x).2 i, rfl, rfl‚ü©‚ü©

/-! ### Essential smallness: `MQ.{u,u} P ‚ČÉ P.M`

Crossing to Mathlib's limit-constructed `P.M` (carriers at `Type u`).
This is the "replacement" step: the big quotient is equivalent to a small
type, because `P.M` itself is a small coalgebra through which every
unfolding factors. -/

section Small

variable {P : PFunctor}

/-- Fold the big quotient into the small `P.M`. -/
def toM : P.MQ ‚Üí P.M := M.corec destructure

/-- Unfold `P.M`, viewed as a (small) coalgebra over itself. -/
def ofM : P.M ‚Üí P.MQ := corec M.dest

/-- Terminal objects are unique: `toM ‚ąė ofM` and `id` are both coalgebra
morphisms `P.M ‚Üí P.M`, so they agree by uniqueness of corecursion into the
terminal coalgebra `P.M`. -/
theorem toM_ofM (m : P.M) : toM (ofM m) = m :=
  congrFun ((M.corec_unique M.dest _ fun x => M.dest_corec destructure (ofM x)).trans
    (M.corec_unique M.dest id fun _ => rfl).symm) m

/-- The other round-trip needs genuine coinduction: the terminality argument
is unavailable here, because `MQ` is only terminal for coalgebras one
universe *below* itself ‚ÄĒ `corec destructure` on the carrier `MQ.{u,v,w}`
lands in `MQ.{u,v,max (w+1) u v}`, so `ofM ‚ąė toM` and `id` cannot both be
compared against it. -/
theorem ofM_toM (q : P.MQ) : ofM (toM q) = q := by
  refine bisim (fun a b => a = ofM (toM b)) ?_ _ _ rfl
  rintro _ b rfl
  exact ‚ü®b.destructure.1, fun i => ofM (toM (b.destructure.2 i)), b.destructure.2,
    congrArg (P.map ofM) (M.dest_corec destructure b), rfl, fun i => rfl‚ü©

/-- P.MQ is essentially small. -/
def equivM : P.MQ ‚ČÉ P.M where
  toFun := toM
  invFun := ofM
  left_inv := ofM_toM
  right_inv := toM_ofM

/-- An inverse to `destructure` by constructing in M-side. -/
def mkM (x : P.Obj P.MQ) : P.MQ := ofM (M.mk (P.map toM x))

@[simp] theorem dest_mkM (x : P.Obj P.MQ) : (mkM x).destructure = x := by
  show P.map ofM (M.dest (M.mk (P.map toM x))) = x
  rw [M.dest_mk, PFunctor.map_map, show ofM ‚ąė toM = id from funext ofM_toM, PFunctor.id_map]

@[simp] theorem mkM_dest (q : P.MQ) : mkM q.destructure = q := by
  rw [mkM, toM, ‚Üź M.dest_corec destructure q, M.mk_dest]
  exact ofM_toM q

end Small

end MQ

end PFunctor
